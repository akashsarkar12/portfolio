body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f4f4;
    color: #333;
}

header {
    background: #0077cc;
    color: white;
    text-align: center;
    padding: 40px;
}

section {
    max-width: 900px;
    margin: 30px auto;
    background: white;
    padding: 20px;
    border-radius: 10px;
}

.about img {
    width: 150px;
    border-radius: 50%;
    display: block;
    margin: 20px auto;
}

.project {
    background: #f8f8f8;
    padding: 15px;
    margin-top: 15px;
    border-left: 5px solid #0077cc;
}

footer {
    text-align: center;
    background: #222;
    color: white;
    padding: 20px;
    margin-top: 40px;
}
